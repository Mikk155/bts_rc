# documentation
*.png binary
*.wav binary
*.ico binary

# Binary game assets
maps/** filter=lfs diff=lfs merge=lfs -text
models/** filter=lfs diff=lfs merge=lfs -text
sound/** filter=lfs diff=lfs merge=lfs -text
sprites/** filter=lfs diff=lfs merge=lfs -text
*.res linguist-vendored
*.as linguist-language=AngelScript
*.predefined linguist-language=AngelScript
*.json linguist-language=AngelScript
docs/* linguist-documentation=false
*.py linguist-language=Python
*.js linguist-language=JavaScript
*.html linguist-language=HTML
*.css linguist-language=HTML
*.md linguist-language=HTML
* !text !filter !merge !diff
