{
    "explorer.excludeGitIgnore": true,

    "files.associations":
    {
        "*.json": "jsonc",
        "*.as": "angelscript"
    },

    "angelScript.explicitPropertyAccessor": false,
    "angelScript.implicitMutualInclusion": true,
    "angelScript.supportsForEach": false,
    "angelScript.forceIncludePredefined": [
        "as.predefined"
    ]
}
