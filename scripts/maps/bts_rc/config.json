{
    // Whatever player voices are enabled
    "voice_responses": true,

    // Whatever to enable blood puddles
    "blood_puddles": true,

    // Whatever that enemies should splash extra blood
    "blood_splash": true,

    // Whatever machine enemies should splash sparks
    "sparks_splash": true,

    // Whatever turrets should have laser aims
    "turret_lasers": true,

    // Whatever to force player models
    "force_playermodels": true,

    // Whatever melee weapons can pull allied players like the crowbar does
    "melee_weapons_pull": true,

    // ===========================
    // Start of configuration contexts
    // ===========================

    // what monsters drop upon death
    "deathdrop":
    {
        // Finds by either classname or model name. model has priority.
        // Values are the classname of entities to spawn, null to have a chance of nothing. "grenade" to spawn a living grenade
        "monster_zombie":
        [
            "ammo_bts_battery",
            "weapon_bts_flare",
            "ammo_bts_dglocksd",
            "item_bts_sprayaid",
            null, // Few chances of droping nothing
            null,
            null
        ],

        "monster_zombie_barney":
        [
            "ammo_bts_dglocksd",
            "ammo_bts_dreagle",
            "ammo_bts_shotshell",
            "ammo_bts_beretta",
            null,
            null,
            null
        ],

        "monster_human_grunt":
        [
            "ammo_bts_556round"
        ],

        "models/bts_rc/monsters/zombie_medic.mdl":
        [
            "item_bts_sprayaid",
            "item_healthkit"
        ],

        "monster_zombie_soldier":
        [
            "ammo_bts_shotshell",
            "ammo_bts_9mmbox",
            "ammo_bts_556round",
            "ammo_bts_357cyl",
            "ammo_bts_dreagle",
            "ammo_bts_dglocksd",
            "item_bts_hevbattery",
            "grenade", "grenade", "grenade", "grenade", "grenade", "grenade", "grenade", "grenade"
        ],

        "monster_gonome":
        [
            "ammo_bts_shotshell",
            "ammo_bts_9mmbox",
            "ammo_bts_556round",
            "ammo_bts_357cyl",
            "ammo_bts_dreagle",
            "ammo_bts_dglocksd",
            "item_bts_hevbattery",
            "grenade", "grenade", "grenade", "grenade", "grenade", "grenade", "grenade", "grenade"
        ]
    },

    "weapon_axe":
    {
        // Attack distance
        "attack_distance": 45,

        // Attack cooldown
        "primary_cooldown": 0.8,
        "primary_miss_cooldown": 1.25,
        "primary_trained_cooldown": 0.4,
        "primary_miss_trained_cooldown": 0.90,
        "secondary_cooldown": 0.5,
        "secondary_trained_cooldown": 0.25,
        "secondary_miss_cooldown": 1.35,
        "secondary_miss_trained_cooldown": 1.0,

        // 50% damage on subsequent hits
        "subsequent_hits_deduction": 0.5,

        "primary_damage": 20,
        "secondary_damage": 14
    }
}