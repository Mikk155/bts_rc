{
    "$schema": "https://json-schema.org/draft/2020-12/schema",

    "type": "object",
    "properties":
    {
        "$schema":
        {
            "type": "string",
            "description": "Reference to the JSON schema file used for validation and editor hinting."
        },
        "characters":
        {
            "type": "array",
            "unevaluatedProperties": false,
            "title": "Playable characters",
            "description": "Define a playable character by name, hands and classification in that order",
            "items":
            {
                "type": "array",
                "title": "Character definition",
                "description": "Define a playable character by name, hands and classification in that order",
                "minItems": 3,
                "maxItems": 3,
                "prefixItems":
                [
                    {
                        "type": "string",
                        "description": "Character model name"
                    },
                    {
                        "type": "integer",
                        "description": "Classification used for the character",
                        "oneOf":
                        [
                            { "const": 0, "description": "Security classify" },
                            { "const": 1, "description": "Scientist classify" },
                            { "const": 2, "description": "Maintenance classify" },
                            { "const": 4, "description": "HEV classify" },
                            { "const": 5, "description": "Hazard classify" },
                            { "const": 6, "description": "Operative classify" }
                        ]
                    },
                    {
                        "type": "integer",
                        "description": "Hands used for the character",
                        "oneOf":
                        [
                            { "const": 0, "description": "Security arms" },
                            { "const": 1, "description": "Scientist arms" },
                            { "const": 2, "description": "Orange Maintenance arms" },
                            { "const": 3, "description": "Black Scientist arms" },
                            { "const": 4, "description": "HEV suit arms" },
                            { "const": 5, "description": "Hazard clean suit arms" },
                            { "const": 6, "description": "Operative arms" },
                            { "const": 7, "description": "Black Security arms" },
                            { "const": 8, "description": "Green Maintenance arms" },
                            { "const": 9, "description": "Operative with gloves arms" }
                        ]
                    }
                ]
            }
        },
        "battery_lighting":
        {
            "title": "Lighting battery",
            "type": "boolean",
            "description": "If enabled, HEV batteries will emit a blue dynamic light.",
            "default": true
        },
        "weapon_bts_axe":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponMelee" } ]
        },
        "weapon_bts_screwdriver":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponMelee" } ]
        },
        "weapon_bts_poolstick":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponMelee" } ]
        },
        "weapon_bts_pipe":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponMelee" } ]
        },
        "weapon_bts_knife":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponMelee" } ]
        },
        "weapon_crowbar":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponMelee" } ]
        },
        "weapon_bts_pipewrench":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponMelee" } ]
        },
        "weapon_medkit":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponConfig" } ],
            "properties":
            {
                "health_ammount":
                {
                    "type": "integer",
                    "description": "Ammount of health to heal"
                },
                "health_gain":
                {
                    "type": "integer"
                },
                "health_cost":
                {
                    "type": "integer"
                }
            }
        },
        "weapon_bts_flashlight":
        {
            "unevaluatedProperties": false,
            "allOf": [ { "$ref": "#/$defs/ASWeaponMelee" } ]
        }
    },
    "$defs":
    {
        "ASWeaponConfig":
        {
            "type": "object",
            "title": "Weapon",
            "description": "Base weapon configuration shared across all weapons.",
            "properties":
            {
                "primary_maxammo":
                {
                    "type": "integer"
                },
                "secondary_maxammo":
                {
                    "type": "integer"
                },
                "primary_dropammo":
                {
                    "type": "integer"
                },
                "secondary_dropammo":
                {
                    "type": "integer"
                },
                "primary_damage":
                {
                    "type": "number"
                },
                "secondary_damage":
                {
                    "type": "number"
                },
                "tertiary_damage":
                {
                    "type": "number"
                },
                "primary_cooldown":
                {
                    "type": "number"
                },
                "secondary_cooldown":
                {
                    "type": "number"
                },
                "tertiary_cooldown":
                {
                    "type": "number"
                },
                "primary_trained_cooldown":
                {
                    "type": "number"
                },
                "secondary_trained_cooldown":
                {
                    "type": "number"
                },
                "tertiary_trained_cooldown":
                {
                    "type": "number"
                },
                "max_clip":
                {
                    "type": "integer"
                },
                "slot":
                {
                    "type": "integer"
                },
                "position":
                {
                    "type": "integer"
                },
                "weight":
                {
                    "type": "integer"
                },
                "deploy_time":
                {
                    "type": "number"
                }
            }
        },
        "ASWeaponMelee":
        {
            "allOf": [ { "$ref": "#/$defs/ASWeaponConfig" } ],
            "type": "object",
            "description": "Melee-specific weapon behavior.",
            "properties":
            {
                "primary_distance":
                {
                    "type": "number"
                },
                "secondary_distance":
                {
                    "type": "number"
                },
                "tertiary_distance":
                {
                    "type": "number"
                },
                "subsequent_hits_deduction":
                {
                    "type": "number",
                    "description": "Damage multiplier applied to consecutive hits."
                },
                "primary_miss_cooldown":
                {
                    "type": "number"
                },
                "primary_miss_trained_cooldown":
                {
                    "type": "number"
                },
                "secondary_miss_cooldown":
                {
                    "type": "number"
                },
                "secondary_miss_trained_cooldown":
                {
                    "type": "number"
                }
            }
        }
    },
    "unevaluatedProperties": false
}
